---
import TableOfContentsHeading from "./TableOfContentsHeading.astro";

// https://kld.dev/building-table-of-contents/
const { headings } = Astro.props;
const toc = buildToc(headings);

export interface Heading {
  depth: number;
  slug: string;
  text: string;
}

function buildToc(headings: Heading[]) {
  const toc: Heading[] = [];
  const parentHeadings = new Map();
  headings.forEach((h) => {
    const heading = { ...h, subheadings: [] };
    parentHeadings.set(heading.depth, heading);
    if (heading.depth === 2) {
      toc.push(heading);
    } else {
      // Fix: Check if parent exists before accessing
      const parent = parentHeadings.get(heading.depth - 1);
      if (parent && parent.subheadings) {
        parent.subheadings.push(heading);
      }
    }
  });
  return toc;
}
---

<nav
  class="animate not-prose my-10 max-w-[560px] rounded-l-none rounded-r-[12px] border border-border border-l-[3px] border-l-accent bg-surface2 px-[26px] pb-[18px] pt-[22px]"
>
  <p class="mb-3.5 font-mono text-[11.5px] uppercase tracking-[2.5px] text-muted">
    Contents
  </p>
  <ul>
    {toc.map((heading, i) => <TableOfContentsHeading heading={heading} index={i + 1} />)}
  </ul>
</nav>