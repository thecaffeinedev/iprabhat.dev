---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/"
    ? pathname === "/"
    : pathname === href || pathname.startsWith(`${href}/`);
---

<header>
  <Container>
    <div class="flex flex-wrap items-center justify-between gap-x-8 gap-y-4">
      <Link href="/" underline={false}>
        <div class="flex items-center gap-2 text-[#25231d] dark:text-[#f5f2ea]">
          <img
            src="/pks.jpeg"
            alt="Prabhat Kumar Sahu"
            class="h-10 w-10 rounded-[0.95rem] object-cover object-center shadow-sm ring-1 ring-black/8 dark:ring-white/10"
          />
          <div class="leading-tight">
            <div class="text-[0.92rem] font-semibold tracking-[-0.01em]">
              Prabhat Kumar Sahu
            </div>
            <div class="text-[0.76rem] text-[#8a8479] dark:text-white/40">
              Writing about software, systems, and life as it unfolds.
            </div>
          </div>
        </div>
      </Link>
      <nav
        class="flex items-center gap-1 text-[0.95rem] font-medium text-[#2f5d3a] dark:text-[#73957a]"
      >
        <a
          href="/blog"
          aria-current={isActive("/blog") ? "page" : undefined}
          class="rounded-lg px-3 py-1.5 transition-colors duration-200 hover:bg-[#3f6a45]/8 dark:hover:bg-white/6"
        >
          blog
        </a>
        <a
          href="/uses"
          aria-current={isActive("/uses") ? "page" : undefined}
          class="rounded-lg px-3 py-1.5 transition-colors duration-200 hover:bg-[#3f6a45]/8 dark:hover:bg-white/6"
        >
          uses
        </a>
        <a
          href="/about"
          aria-current={isActive("/about") ? "page" : undefined}
          class="rounded-lg px-3 py-1.5 transition-colors duration-200 hover:bg-[#3f6a45]/8 dark:hover:bg-white/6"
        >
          about
        </a>
        <button
          id="theme-toggle"
          aria-label="Toggle theme"
          class="group ml-2 flex items-center justify-center rounded-full border border-black/8 px-3 py-1.5 text-[#7a766d] transition-colors duration-200 hover:border-[#2f5d3a]/25 hover:text-[#1d4427] dark:border-white/10 dark:text-white/45 dark:hover:border-[#73957a]/30 dark:hover:text-[#d7ead9]"
        >
          <svg
            id="theme-toggle-light-icon"
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="hidden dark:block"
          >
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
          </svg>
          <svg
            id="theme-toggle-dark-icon"
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="block dark:hidden"
          >
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>
      </nav>
    </div>
  </Container>
</header>
