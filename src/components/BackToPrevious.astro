---
type Props = {
  href: string;
};

const { href } = Astro.props;
---

<a
  href={href}
  class="not-prose inline-flex w-fit items-center gap-2 rounded-[9px] border border-border bg-surface px-4 py-[9px] text-[14px] font-medium text-ink transition-colors hover:border-accent"
>
  <span aria-hidden="true">&lsaquo;</span>
  <span><slot /></span>
</a>
