---
import Container from "@components/Container.astro";
import { SITE } from "@consts";
---

<footer class="animate">
  <Container>
    <div class="space-y-8 border-t border-black/6 pt-8 dark:border-white/8">
      <div class="flex justify-end">
        <button
          id="back-to-top"
          aria-label="Back to top of page"
          class="group relative flex w-fit flex-nowrap rounded-full border border-black/8 py-2 pr-4 pl-9 text-sm text-[#7a766d] transition-colors duration-300 ease-in-out hover:border-[#3f6a45]/30 hover:bg-[#e2ece1] hover:text-[#21492b] focus-visible:border-[#3f6a45]/30 focus-visible:bg-[#e2ece1] focus-visible:text-[#21492b] dark:border-white/10 dark:text-white/45 dark:hover:border-[#7ea184]/35 dark:hover:bg-white/5 dark:hover:text-[#d0e6d2] dark:focus-visible:border-[#7ea184]/35 dark:focus-visible:bg-white/5 dark:focus-visible:text-[#d0e6d2]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            class="absolute top-1/2 left-2 size-4 -translate-y-1/2 fill-none stroke-current stroke-2"
          >
            <line
              x1="12"
              y1="19"
              x2="12"
              y2="5"
              class="translate-y-3 scale-y-0 transition-transform duration-300 ease-in-out group-hover:translate-y-0 group-hover:scale-y-100 group-focus-visible:translate-y-0 group-focus-visible:scale-y-100"
            ></line>
            <polyline
              points="5 12 12 5 19 12"
              class="translate-y-1 transition-transform duration-300 ease-in-out group-hover:translate-y-0 group-focus-visible:translate-y-0"
            ></polyline>
          </svg>
          <div>Back to top</div>
        </button>
      </div>
      <div class="pb-2 text-sm text-[#7a766d] dark:text-white/45">
        © {new Date().getFullYear()}
        {SITE.TITLE}
      </div>
    </div>
  </Container>
</footer>
