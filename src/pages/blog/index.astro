---
import { type CollectionEntry, getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { BLOG } from "@consts";

const data = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

type Acc = {
  [year: string]: CollectionEntry<"blog">[];
};

const posts = data.reduce((acc: Acc, post) => {
  const year = post.data.date.getFullYear().toString();
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push(post);
  return acc;
}, {});

const years = Object.keys(posts).sort((a, b) => parseInt(b) - parseInt(a));

// Get all unique tags with counts, sorted alphabetically
const tagCounts = data.reduce(
  (acc, post) => {
    post.data.tags?.forEach((tag) => {
      acc[tag] = (acc[tag] || 0) + 1;
    });
    return acc;
  },
  {} as Record<string, number>,
);

const allTags = Object.entries(tagCounts).sort((a, b) =>
  a[0].localeCompare(b[0]),
);

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    month: "short",
    day: "2-digit",
  });
}
---

<Layout title={BLOG.TITLE} description={BLOG.DESCRIPTION}>
  <Container>
    <div class="space-y-12">
      <div class="animate space-y-4">
        <h1
          class="font-serif text-3xl font-semibold text-black dark:text-white"
        >
          Blog
        </h1>

        <nav
          class="flex flex-wrap gap-2 text-[0.92rem]"
          aria-label="Filter posts by tag"
        >
          <button
            data-tag="all"
            class="tag-filter tag-filter-active rounded-full border border-black/8 px-2.5 py-1 text-[#7a766d] transition-all duration-200 hover:border-[#3f6a45]/25 hover:bg-[#e2ece1] hover:text-[#21492b] dark:border-white/10 dark:text-white/45 dark:hover:border-[#7ea184]/30 dark:hover:bg-white/5 dark:hover:text-[#d0e6d2]"
          >
            all
          </button>
          {
            allTags.map(([tag, count]) => (
              <button
                data-tag={tag}
                class="tag-filter rounded-full border border-black/8 px-2.5 py-1 text-[#7a766d] transition-all duration-200 hover:border-[#3f6a45]/25 hover:bg-[#e2ece1] hover:text-[#21492b] dark:border-white/10 dark:text-white/45 dark:hover:border-[#7ea184]/30 dark:hover:bg-white/5 dark:hover:text-[#d0e6d2]"
              >
                {tag}
                <span class="ml-1 text-[0.76em] opacity-55">({count})</span>
              </button>
            ))
          }
        </nav>
      </div>

      <div class="space-y-12" id="posts-container">
        {
          years.map((year) => (
            <section
              class="animate space-y-5 border-t border-black/6 pt-8 first:border-t-0 first:pt-0 dark:border-white/8"
              data-year={year}
            >
              <div class="flex items-center gap-4">
                <h2 class="font-serif text-lg text-[#3f6a45] dark:text-[#7ea184]">
                  {year}
                </h2>
                <div class="h-px flex-1 bg-black/6 dark:bg-white/8" />
              </div>
              <ul class="space-y-1">
                {posts[year].map((post) => (
                  <li
                    class="post-item border-b border-black/4 py-3 last:border-b-0 dark:border-white/6"
                    data-tags={post.data.tags?.join(",") || ""}
                  >
                    <Link href={`/blog/${post.id}`} underline={false} group>
                      <div class="group grid gap-1 sm:grid-cols-[minmax(0,1fr)_88px] sm:items-baseline sm:gap-6">
                        <div class="min-w-0 text-[1.06rem] text-black transition-colors duration-200 group-hover:text-[#21492b] dark:text-white dark:group-hover:text-[#d0e6d2]">
                          <span class="relative after:absolute after:bottom-0 after:left-0 after:h-[1px] after:w-0 after:bg-[#3f6a45]/45 after:transition-all after:duration-300 group-hover:after:w-full group-active:after:w-full dark:after:bg-[#7ea184]/45">
                            {post.data.title}
                          </span>
                        </div>
                        <div class="text-sm whitespace-nowrap text-[#a29a8f] tabular-nums sm:text-right dark:text-white/40">
                          {formatDate(post.data.date)}
                        </div>
                      </div>
                    </Link>
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </div>
    </div>
  </Container>
</Layout>

<style>
  .tag-filter-active {
    color: #21492b;
    border-color: rgba(63, 106, 69, 0.28);
    background: #e2ece1;
  }

  .dark .tag-filter-active {
    color: #d0e6d2;
    border-color: rgba(126, 161, 132, 0.3);
    background: rgba(255, 255, 255, 0.05);
  }
</style>

<script>
  function initTagFilters() {
    const tagFilters = document.querySelectorAll(".tag-filter[data-tag]");
    const postItems = document.querySelectorAll(".post-item");
    const yearSections = document.querySelectorAll("[data-year]");

    const allFilter = document.querySelector('.tag-filter[data-tag="all"]');

    tagFilters.forEach((filter) => {
      filter.addEventListener("click", () => {
        let selectedTag = filter.getAttribute("data-tag");

        // Toggle: clicking active tag resets to "all"
        if (
          selectedTag !== "all" &&
          filter.classList.contains("tag-filter-active")
        ) {
          selectedTag = "all";
          tagFilters.forEach((f) => f.classList.remove("tag-filter-active"));
          allFilter?.classList.add("tag-filter-active");
        } else {
          tagFilters.forEach((f) => f.classList.remove("tag-filter-active"));
          filter.classList.add("tag-filter-active");
        }

        // Scroll to top of blog list
        document.getElementById("posts-container")?.scrollIntoView({
          behavior: "smooth",
          block: "start",
        });

        // Filter posts
        postItems.forEach((item) => {
          const postTags = item.getAttribute("data-tags");
          if (selectedTag === "all" || postTags?.includes(selectedTag || "")) {
            (item as HTMLElement).style.display = "";
          } else {
            (item as HTMLElement).style.display = "none";
          }
        });

        // Hide empty year sections
        yearSections.forEach((section) => {
          const visiblePosts = section.querySelectorAll(
            '.post-item:not([style*="display: none"])',
          );
          if (visiblePosts.length === 0) {
            (section as HTMLElement).style.display = "none";
          } else {
            (section as HTMLElement).style.display = "";
          }
        });
      });
    });
  }

  initTagFilters();
  document.addEventListener("astro:after-swap", initTagFilters);
</script>
