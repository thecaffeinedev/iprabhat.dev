---
import { type CollectionEntry, getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { BLOG } from "@consts";

const data = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

type Acc = {
  [year: string]: CollectionEntry<"blog">[];
};

const posts = data.reduce((acc: Acc, post) => {
  const year = post.data.date.getFullYear().toString();
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push(post);
  return acc;
}, {});

const years = Object.keys(posts).sort((a, b) => parseInt(b) - parseInt(a));

// Get all unique tags with counts, sorted alphabetically
const tagCounts = data.reduce((acc, post) => {
  post.data.tags?.forEach(tag => {
    acc[tag] = (acc[tag] || 0) + 1;
  });
  return acc;
}, {} as Record<string, number>);

const allTags = Object.entries(tagCounts).sort((a, b) => a[0].localeCompare(b[0]));

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    month: "short",
    day: "2-digit",
  });
}
---

<Layout title={BLOG.TITLE} description={BLOG.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <div class="animate">
        <h1 class="text-3xl font-medium text-black dark:text-white">
          Blog
        </h1>

        <!-- Inline tag filter -->
        <nav class="mt-4 flex flex-wrap items-center gap-x-1.5 gap-y-1 font-mono text-xs text-[#6b6b6b] dark:text-white/50">
          <button
            data-tag="all"
            class="tag-filter tag-filter-active transition-colors duration-200"
          >
            all
          </button>
          {
            allTags.map(([tag], i) => (
              <>
                <span class="text-black/20 dark:text-white/20">·</span>
                <button
                  data-tag={tag}
                  class="tag-filter transition-colors duration-200 hover:text-[#b35c3a] dark:hover:text-[#d99068]"
                >
                  {tag}
                </button>
              </>
            ))
          }
        </nav>
      </div>

      <div class="space-y-12" id="posts-container">
        {
          years.map((year) => (
            <section class="animate space-y-4" data-year={year}>
              <h2 class="text-base font-mono text-[#b35c3a] dark:text-[#d99068] tracking-wide">
                {year}
              </h2>
              <ul class="space-y-3">
                {posts[year].map((post) => (
                  <li
                    class="post-item"
                    data-tags={post.data.tags?.join(",") || ""}
                  >
                    <Link
                      href={`/blog/${post.id}`}
                      underline={false}
                    >
                      <div class="flex justify-between items-baseline gap-4 group">
                        <div class="text-black group-hover:text-[#b35c3a] dark:text-white dark:group-hover:text-[#d99068] transition-colors duration-200 flex-1">
                          <span class="relative after:absolute after:bottom-0 after:left-0 after:h-[1px] after:w-0 after:bg-[#b35c3a]/40 after:transition-all after:duration-300 group-hover:after:w-full group-active:after:w-full dark:after:bg-[#d99068]/40">
                            {post.data.title}
                          </span>
                        </div>
                        <div class="font-mono text-xs text-[#6b6b6b] dark:text-white/50 whitespace-nowrap tabular-nums">
                          {formatDate(post.data.date)}
                        </div>
                      </div>
                    </Link>
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </div>
    </div>
  </Container>
</Layout>

<style>
  .tag-filter-active {
    color: #b35c3a;
  }

  .dark .tag-filter-active {
    color: #d99068;
  }
</style>

<script>
  function initTagFilters() {
    const tagFilters = document.querySelectorAll('.tag-filter[data-tag]');
    const postItems = document.querySelectorAll('.post-item');
    const yearSections = document.querySelectorAll('[data-year]');

    const allFilter = document.querySelector('.tag-filter[data-tag="all"]');

    tagFilters.forEach(filter => {
      filter.addEventListener('click', () => {
        let selectedTag = filter.getAttribute('data-tag');

        // Toggle: clicking active tag resets to "all"
        if (selectedTag !== 'all' && filter.classList.contains('tag-filter-active')) {
          selectedTag = 'all';
          tagFilters.forEach(f => f.classList.remove('tag-filter-active'));
          allFilter?.classList.add('tag-filter-active');
        } else {
          tagFilters.forEach(f => f.classList.remove('tag-filter-active'));
          filter.classList.add('tag-filter-active');
        }

        // Scroll to top of blog list
        document.getElementById('posts-container')?.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });

        // Filter posts
        postItems.forEach(item => {
          const postTags = item.getAttribute('data-tags');
          if (selectedTag === 'all' || postTags?.includes(selectedTag || '')) {
            (item as HTMLElement).style.display = '';
          } else {
            (item as HTMLElement).style.display = 'none';
          }
        });

        // Hide empty year sections
        yearSections.forEach(section => {
          const visiblePosts = section.querySelectorAll('.post-item:not([style*="display: none"])');
          if (visiblePosts.length === 0) {
            (section as HTMLElement).style.display = 'none';
          } else {
            (section as HTMLElement).style.display = '';
          }
        });
      });
    });
  }

  initTagFilters();
  document.addEventListener('astro:after-swap', initTagFilters);
</script>
