---
import { type CollectionEntry, getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { BLOG } from "@consts";

const data = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

type Acc = {
  [year: string]: CollectionEntry<"blog">[];
};

const posts = data.reduce((acc: Acc, post) => {
  const year = post.data.date.getFullYear().toString();
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push(post);
  return acc;
}, {});

const years = Object.keys(posts).sort((a, b) => parseInt(b) - parseInt(a));

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    month: "short",
    day: "2-digit",
  });
}
---

<Layout title={BLOG.TITLE} description={BLOG.DESCRIPTION}>
  <Container>
    <div>
      <div class="animate">
        <h1 class="mt-4 mb-[22px] text-[34px] font-extrabold tracking-[-2px] text-ink sm:text-[46px]">
          Blog
        </h1>
        <p class="max-w-[560px] text-[17px] leading-[1.7] text-body">
          I keep meaning to write more. Haven't quite gotten there yet. Everything I've published so far, feel free to browse by <Link href="/tags" underline={false} class="text-accent underline decoration-[1.5px] underline-offset-[3px] hover:text-accent">topic</Link>.
        </p>
      </div>

      <div id="posts-container">
        {
          years.map((year) => (
            <section class="animate" data-year={year}>
              <div class="mt-10 h-px bg-border"></div>
              <h2 class="mt-11 mb-1 text-[22px] font-bold text-ink">
                {year} <span class="font-bold text-accent">({posts[year].length})</span>
              </h2>
              <ul>
                {posts[year].map((post) => (
                  <li
                    class="post-item"
                    data-tags={post.data.tags?.join(",") || ""}
                  >
                    <a
                      href={`/blog/${post.id}`}
                      class="-mx-3.5 grid grid-cols-[1fr_auto] items-center gap-[22px] rounded-[10px] border-b border-border px-3.5 py-[19px] transition-colors hover:bg-surface2"
                    >
                      <span class="text-[18px] font-semibold leading-[1.3] text-ink">
                        {post.data.title}
                      </span>
                      <span class="whitespace-nowrap font-mono text-[13px] text-muted tabular-nums">
                        {formatDate(post.data.date)}
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </div>

    </div>
  </Container>
</Layout>

