---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { SITE, HOME, SOCIALS } from "@consts";
import Link from "@components/Link.astro";
import { getCollection } from "astro:content";

const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "2-digit",
  });
}
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <aside data-pagefind-ignore>
      <div
        class="flex flex-col items-start gap-11 pt-4 sm:flex-row sm:justify-between"
      >
        <div class="min-w-0 flex-1">
          <h1 class="animate text-[38px] font-extrabold leading-[1.04] tracking-[-2px] text-ink sm:text-[52px]">
            Hello,<br />I'm Prabhat
          </h1>
          <div class="animate mt-6 max-w-[430px] space-y-[18px] text-[17px] leading-[1.7] text-body">
            <p>
              I work on ML infrastructure and backend systems. This site is a
              mix of engineering notes, travel stories, life updates, and
              things I'm learning.
            </p>
            <p>
              Outside work, I'm usually cafe-hopping for good coffee,
              watching something good, or trying to keep life simple enough
              to pay attention.
            </p>
          </div>

          <ul class="animate mt-[30px] flex flex-wrap gap-2.5">
            {
              SOCIALS.map((social) => (
                <li>
                  <a
                    href={social.HREF}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`${SITE.TITLE} on ${social.NAME}`}
                    class="block rounded-[9px] border border-border bg-surface px-[17px] py-[9px] text-[14px] font-medium text-ink transition-colors hover:border-accent hover:text-accent"
                  >
                    {social.NAME === "X (formerly Twitter)" ? "Twitter" : social.NAME}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="animate hidden shrink-0 sm:block">
          <img
            src="/pks.jpeg"
            alt="Prabhat Kumar Sahu"
            class="h-[248px] w-[208px] rounded-[18px] object-cover object-top"
          />
        </div>
      </div>

      <div class="mt-16">
        <section class="animate">
          <div class="flex items-center justify-between border-b border-border pb-3.5">
            <span class="font-mono text-[12.5px] uppercase tracking-[2.5px] text-muted">
              Latest Posts
            </span>
            <Link href="/blog" underline={false} class="text-[14px] text-accent transition-opacity hover:opacity-70">
              See all posts →
            </Link>
          </div>

          <ul>
            {
              blog.map((post, i) => (
                <li>
                  <a
                    href={`/blog/${post.id}`}
                    class="-mx-3.5 grid grid-cols-[auto_1fr_auto] items-center gap-[22px] rounded-[10px] border-b border-border px-3.5 py-[19px] transition-colors hover:bg-surface2"
                  >
                    <span class="font-mono text-[15px] font-medium text-accent">
                      {String(i + 1).padStart(2, "0")}
                    </span>
                    <span class="text-[18px] font-semibold leading-[1.3] text-ink">
                      {post.data.title}
                    </span>
                    <span class="whitespace-nowrap font-mono text-[13px] text-muted tabular-nums">
                      {formatDate(post.data.date)}
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
        </section>
      </div>
    </aside>
  </Container>
</Layout>
