---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { SITE, HOME, SOCIALS } from "@consts";
import Link from "@components/Link.astro";
import { getCollection } from "astro:content";

const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "2-digit",
  });
}
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <aside data-pagefind-ignore class="space-y-14">
      <section
        class="animate max-w-[40rem] space-y-5 pt-4 sm:space-y-6 sm:pt-6"
      >
        <p
          class="font-serif text-[2rem] leading-tight font-semibold tracking-[-0.02em] text-[#25231d] sm:text-[2.3rem] dark:text-[#f5f2ea]"
        >
          Hello, I&apos;m Prabhat
        </p>
        <div
          class="max-w-[34rem] space-y-4 text-[1.06rem] leading-8 text-[#4e4a43] sm:text-[1.09rem] sm:leading-9 dark:text-white/72"
        >
          <p>
            I work on ML infrastructure and backend systems, with a generalist
            mindset that lets me move across the stack when needed. This site is
            a mix of engineering notes, travel stories, life updates, and things
            I&apos;m learning.
          </p>
          <p>
            Outside work, I&apos;m usually reading, lifting, watching something
            good, or trying to keep life simple enough to pay attention.
          </p>
        </div>
        <ul
          class="flex flex-wrap items-center gap-x-5 gap-y-2 text-[0.9rem] text-[#6a665f] dark:text-white/45"
        >
          {
            SOCIALS.map((social) => (
              <li>
                <Link
                  href={social.HREF}
                  external
                  class="border-b border-transparent px-0 py-0 text-[#7a766d] no-underline hover:border-[#3f6a45]/30 hover:text-[#21492b] dark:text-white/45 dark:hover:text-[#d0e6d2]"
                >
                  {social.NAME.replace("X (formerly Twitter)", "X")}
                </Link>
              </li>
            ))
          }
          <li>
            <Link
              href={`mailto:${SITE.EMAIL}`}
              external
              class="border-b border-transparent px-0 py-0 text-[#7a766d] no-underline hover:border-[#3f6a45]/30 hover:text-[#21492b] dark:text-white/45 dark:hover:text-[#d0e6d2]"
            >
              Email
            </Link>
          </li>
        </ul>
      </section>

      <section class="animate space-y-4 sm:space-y-5">
        <div
          class="flex items-end justify-between gap-3 border-b border-black/6 pb-3 dark:border-white/8"
        >
          <h2
            class="font-serif text-2xl font-semibold text-[#25231d] dark:text-[#f5f2ea]"
          >
            Writing
          </h2>
          <Link
            href="/blog"
            class="text-sm text-[#7a766d] sm:mr-2 dark:text-white/45"
          >
            view archive
          </Link>
        </div>

        <ul class="space-y-3 sm:space-y-4">
          {
            blog.map((post) => (
              <li class="border-b border-black/6 pb-4 last:border-b-0 dark:border-white/8">
                <Link href={`/blog/${post.id}`} underline={false} group>
                  <div class="group flex flex-col gap-1.5 sm:flex-row sm:items-baseline sm:justify-between sm:gap-6">
                    <div class="flex-1 text-[1.02rem] leading-8 font-medium text-[#25231d] transition-colors duration-200 group-hover:text-[#21492b] sm:text-[1.05rem] sm:leading-normal dark:text-[#f5f2ea] dark:group-hover:text-[#d0e6d2]">
                      {post.data.title}
                    </div>
                    <div class="text-sm text-[#938d82] tabular-nums sm:min-w-[110px] sm:text-right dark:text-white/40">
                      {formatDate(post.data.date)}
                    </div>
                  </div>
                </Link>
              </li>
            ))
          }
        </ul>
      </section>
    </aside>
  </Container>
</Layout>
