---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { SITE, HOME, SOCIALS } from "@consts";
import Link from "@components/Link.astro";
import { getCollection } from "astro:content";

const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "2-digit",
  });
}
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <aside data-pagefind-ignore class="space-y-14">
      <section class="animate max-w-[42rem] space-y-6 pt-6">
        <p
          class="text-sm tracking-[0.18em] text-[#3f6a45] uppercase dark:text-[#7ea184]"
        >
          Hello, I&apos;m Prabhat
        </p>
        <h1
          class="max-w-[14ch] font-serif text-3xl font-semibold tracking-[-0.03em] text-[#25231d] sm:text-4xl dark:text-[#f5f2ea]"
        >
          Writing about software, systems, and life as it unfolds.
        </h1>
        <div
          class="max-w-[38rem] space-y-4 text-[1.05rem] leading-8 text-[#4e4a43] dark:text-white/70"
        >
          <p>
            I work on ML infrastructure and backend systems, with a generalist
            mindset that lets me move across the stack when needed. This site is
            a mix of engineering notes, travel stories, life updates, and things
            I&apos;m learning.
          </p>
          <p>
            Outside work, I&apos;m usually reading, lifting, watching something
            good, or trying to keep life simple enough to pay attention.
          </p>
        </div>
        <ul
          class="flex flex-wrap items-center gap-x-4 gap-y-2 text-[0.95rem] text-[#6a665f] dark:text-white/45"
        >
          {
            SOCIALS.map((social) => (
              <li>
                <Link
                  href={social.HREF}
                  external
                  class="rounded-full border border-black/8 px-3 py-1 text-[#7a766d] no-underline hover:border-[#3f6a45]/25 hover:bg-[#e2ece1] dark:border-white/10 dark:text-white/45 dark:hover:bg-white/5"
                >
                  {social.NAME.replace("X (formerly Twitter)", "X")}
                </Link>
              </li>
            ))
          }
          <li>
            <Link
              href={`mailto:${SITE.EMAIL}`}
              external
              class="rounded-full border border-black/8 px-3 py-1 text-[#7a766d] no-underline hover:border-[#3f6a45]/25 hover:bg-[#e2ece1] dark:border-white/10 dark:text-white/45 dark:hover:bg-white/5"
            >
              Email
            </Link>
          </li>
        </ul>
      </section>

      <section class="animate space-y-5">
        <div
          class="flex items-center justify-between gap-4 border-b border-black/6 pb-3 dark:border-white/8"
        >
          <h2
            class="font-serif text-2xl font-semibold text-[#25231d] dark:text-[#f5f2ea]"
          >
            Writing
          </h2>
          <Link href="/blog" class="text-sm text-[#7a766d] dark:text-white/45">
            view archive
          </Link>
        </div>

        <ul class="space-y-4">
          {
            blog.map((post) => (
              <li class="border-b border-black/6 pb-4 last:border-b-0 dark:border-white/8">
                <Link href={`/blog/${post.id}`} underline={false} group>
                  <div class="group flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between sm:gap-6">
                    <div class="flex-1 text-[1.05rem] font-medium text-[#25231d] transition-colors duration-200 group-hover:text-[#21492b] dark:text-[#f5f2ea] dark:group-hover:text-[#d0e6d2]">
                      {post.data.title}
                    </div>
                    <div class="text-sm text-[#938d82] tabular-nums dark:text-white/40">
                      {formatDate(post.data.date)}
                    </div>
                  </div>
                </Link>
              </li>
            ))
          }
        </ul>
      </section>
    </aside>
  </Container>
</Layout>
