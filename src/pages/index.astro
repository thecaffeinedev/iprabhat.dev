---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { SITE, HOME, SOCIALS } from "@consts";
import Link from "@components/Link.astro";
import { getCollection } from "astro:content";

const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "2-digit",
  });
}
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <aside data-pagefind-ignore class="space-y-16 sm:space-y-20">
      <section
        class="animate max-w-[37rem] space-y-6 pt-6 sm:space-y-7 sm:pt-10"
      >
        <p
          class="font-serif text-[1.92rem] leading-tight font-semibold tracking-[-0.02em] text-[#25231d] sm:text-[2.22rem] dark:text-[#f5f2ea]"
        >
          Hello, I&apos;m Prabhat
        </p>
        <div class="max-w-[31rem] space-y-5">
          <p
            class="text-[0.96rem] leading-[1.75] text-[#4e4a43] [text-wrap:pretty] sm:text-[1rem] dark:text-white/72"
          >
            I work on ML infrastructure and backend systems, with a generalist
            mindset driven by curiosity. This site is a mix of engineering
            notes, travel stories, life updates, and things I&apos;m learning.
          </p>
          <p
            class="text-[0.96rem] leading-[1.75] text-[#4e4a43] [text-wrap:pretty] sm:text-[1rem] dark:text-white/72"
          >
            Outside work, I&apos;m usually cafe-hopping for good coffee,
            watching something good, or trying to keep life simple
            enough to pay attention.
          </p>
        </div>
        <ul
          class="flex flex-wrap items-center gap-x-5 gap-y-2 pt-3"
        >
          {
            SOCIALS.map((social) => (
              <li>
                <Link
                  href={social.HREF}
                  external
                  class="inline-flex items-center gap-1.5 border-b border-transparent px-0 py-0 text-[0.89rem] text-[#6b675f] no-underline transition-colors duration-200 hover:border-[#2f5d3a]/30 hover:text-[#1d4427] dark:text-white/66 dark:hover:border-[#73957a]/40 dark:hover:text-[#e7f3e8]"
                >
                  {social.ICON === "x" && (
                    <svg class="size-[15px]" viewBox="0 0 24 24" fill="currentColor"><path d="M13.6823 10.6218L20.2391 3H18.6854L12.9921 9.61788L8.44486 3H3.2002L10.0765 13.0074L3.2002 21H4.75404L10.7663 14.0113L15.5685 21H20.8131L13.6819 10.6218H13.6823ZM11.5541 13.0956L10.8574 12.0991L5.31391 4.16971H7.70053L12.1742 10.5689L12.8709 11.5655L18.6861 19.8835H16.2995L11.5541 13.096V13.0956Z"/></svg>
                  )}
                  {social.ICON === "github" && (
                    <svg class="size-[15px]" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
                  )}
                  {social.ICON === "linkedin" && (
                    <svg class="size-[14px]" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                  )}
                  {social.ICON === "instagram" && (
                    <svg class="size-[14px]" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                  )}
                  {social.ICON !== "x" && social.NAME.replace("X (formerly Twitter)", "X")}
                </Link>
              </li>
            ))
          }
          <li>
            <Link
              href={`mailto:${SITE.EMAIL}`}
              external
              class="inline-flex items-center gap-1.5 border-b border-transparent px-0 py-0 text-[0.89rem] text-[#6b675f] no-underline transition-colors duration-200 hover:border-[#2f5d3a]/30 hover:text-[#1d4427] dark:text-white/66 dark:hover:border-[#73957a]/40 dark:hover:text-[#e7f3e8]"
            >
              <svg class="size-[14px]" viewBox="0 0 24 24" fill="currentColor"><path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z"/><path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z"/></svg>
              Email
            </Link>
          </li>
        </ul>
      </section>

      <section class="animate space-y-6">
        <div
          class="flex items-end justify-between gap-3 border-b border-black/6 pb-3 dark:border-white/8"
        >
          <h2
            class="font-serif text-[1.55rem] font-semibold text-[#25231d] dark:text-[#f5f2ea]"
          >
            Writing
          </h2>
          <Link
            href="/blog"
            class="text-sm text-[#6b675f] sm:mr-2 dark:text-white/56 dark:hover:text-[#dcecdc]"
          >
            view archive
          </Link>
        </div>

        <ul class="space-y-4">
          {
            blog.map((post) => (
              <li class="border-b border-black/6 pb-4 last:border-b-0 dark:border-white/8">
                <Link href={`/blog/${post.id}`} underline={false} group>
                  <div class="group flex flex-col gap-1.5 sm:flex-row sm:items-baseline sm:justify-between sm:gap-6">
                    <div class="flex-1 text-[1rem] leading-7 font-medium text-[#25231d] transition-colors duration-200 group-hover:text-[#1d4427] sm:text-[1.03rem] sm:leading-normal dark:text-[#f5f2ea] dark:group-hover:text-[#d7ead9]">
                      {post.data.title}
                    </div>
                    <div class="text-sm text-[#6b675f] tabular-nums sm:min-w-[110px] sm:text-right dark:text-white/60">
                      {formatDate(post.data.date)}
                    </div>
                  </div>
                </Link>
              </li>
            ))
          }
        </ul>
      </section>
    </aside>
  </Container>
</Layout>
