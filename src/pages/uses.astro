---
import { getEntry, render } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";

const entry = await getEntry("uses", "index");

if (!entry) {
  return Astro.redirect("/404");
}

const { Content } = await render(entry);
---

<Layout title={entry.data.title} description={entry.data.description}>
  <Container>
    <div class="space-y-8">
      <div class="animate">
        <h1 class="mt-4 text-[34px] font-extrabold tracking-[-2px] text-ink sm:text-[46px]">
          {entry.data.title}
        </h1>
      </div>

      <article class="uses-content animate prose dark:prose-invert">
        <Content />
      </article>
    </div>
  </Container>
</Layout>